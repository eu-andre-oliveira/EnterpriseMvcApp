@model ClienteViewModel
@{
    ViewData["Title"] = "Novo Cliente";
}

<div class="container-fluid px-0">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">Dados do Cliente</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Nome" class="form-label"></label>
                        <input asp-for="Nome" class="form-control" />
                        <span asp-validation-for="Nome" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CnpjCpf" class="form-label">CNPJ/CPF</label>
                        <input asp-for="CnpjCpf" class="form-control" />
                        <span asp-validation-for="CnpjCpf" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Telefone" class="form-label"></label>
                        <input asp-for="Telefone" class="form-control" />
                        <span asp-validation-for="Telefone" class="text-danger"></span>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <div class="form-check mb-2">
                            <input asp-for="Ativo" class="form-check-input" />
                            <label asp-for="Ativo" class="form-check-label"></label>
                        </div>

                    </div>
                   <div class="col-md-6">  
                    <label asp-for="OrigemCliente" class="form-label">Origem do Cliente</label>
                    <input asp-for="OrigemCliente" class="form-control" placeholder="Ex: Indicação, Site, Redes Sociais..." />
                    <span asp-validation-for="OrigemCliente" class="text-danger"></span>
                </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Contatos do Cliente</h5>
                <button type="button" id="btnAdicionarContato" class="btn btn-primary btn-sm">+ Adicionar Contato</button>
            </div>
            <div class="card-body">
                <div id="contatosContainer">
                    @for (var i = 0; i < Model.Contatos.Count; i++)
                    {
                        @await Html.PartialAsync("~/Views/Cliente/_ContatoPartial.cshtml", Model.Contatos[i], new ViewDataDictionary(ViewData) { ["Index"] = i.ToString() })
                    }
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">Salvar</button>
            <a asp-action="Index" class="btn btn-secondary">Voltar</a>
        </div>
    </form>
</div>

<template id="contatoTemplate">
@await Html.PartialAsync("~/Views/Cliente/_ContatoPartial.cshtml", new ContatoClienteViewModel(), new ViewDataDictionary(ViewData) { ["Index"] = "__index__" })
</template>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const container = document.getElementById('contatosContainer');
            const template = document.getElementById('contatoTemplate');
            const addBtn = document.getElementById('btnAdicionarContato');

            const getNextIndex = () => container.querySelectorAll('.contato-item').length;

            const resetValidation = () => {
                if (window.jQuery) {
                    const form = jQuery('form');
                    form.removeData('validator');
                    form.removeData('unobtrusiveValidation');
                    jQuery.validator.unobtrusive.parse(form);
                }
            };

            const reindexContatos = () => {
                const itens = container.querySelectorAll('.contato-item');
                itens.forEach((item, index) => {
                    item.dataset.index = index;
                    item.querySelectorAll('[name]').forEach(el => {
                        el.name = el.name.replace(/Contatos\[\d+\]|Contatos\[__index__\]/g, `Contatos[${index}]`);
                    });
                    item.querySelectorAll('[data-valmsg-for]').forEach(el => {
                        el.setAttribute('data-valmsg-for', el.getAttribute('data-valmsg-for').replace(/Contatos\[\d+\]|Contatos\[__index__\]/g, `Contatos[${index}]`));
                    });
                });
                resetValidation();
            };

            addBtn.addEventListener('click', () => {
                const index = getNextIndex();
                const html = template.innerHTML.replaceAll('__index__', index.toString());
                container.insertAdjacentHTML('beforeend', html);
                resetValidation();
            });

            container.addEventListener('click', (e) => {
                if (e.target.classList.contains('btn-remover-contato')) {
                    e.target.closest('.contato-item')?.remove();
                    reindexContatos();
                }
            });
        })();
    </script>
}
