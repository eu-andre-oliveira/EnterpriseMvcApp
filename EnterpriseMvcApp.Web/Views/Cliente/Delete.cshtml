@model ClienteViewModel
@{
    ViewData["Title"] = "Excluir Cliente";
}

@if (TempData["Erro"] is string erro)
{
    <div class="alert alert-danger">@erro</div>
}

<div class="card shadow-sm">
    <div class="card-header bg-light">
        <h5 class="mb-0">Confirmação de Exclusão</h5>
    </div>
    <div class="card-body">
        <p>Tem certeza que deseja excluir este cliente?</p>

        <dl class="row mb-0">
            <dt class="col-sm-2">Nome</dt>
            <dd class="col-sm-10">@Model.Nome</dd>

            <dt class="col-sm-2">CNPJ/CPF</dt>
            <dd class="col-sm-10">@Model.CnpjCpf</dd>

            <dt class="col-sm-2">Email</dt>
            <dd class="col-sm-10">@Model.Email</dd>
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger">Confirmar Exclusão</button>
        </form>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </div>
</div>
