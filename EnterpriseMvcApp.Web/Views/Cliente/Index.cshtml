@model IEnumerable<ClienteViewModel>
@{
    ViewData["Title"] = "Clientes";
}

@if (TempData["Sucesso"] is string sucesso)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @sucesso
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Erro"] is string erro)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @erro
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Cadastro de Clientes</h5>
        <a asp-action="Create" class="btn btn-primary">Novo Cliente</a>
    </div>
    <div class="card-body table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Nome</th>
                    <th>CNPJ/CPF</th>
                    <th>Email</th>
                    <th>Telefone</th>
                    <th>Ativo</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cliente in Model)
                {
                    <tr>
                        <td>@cliente.Nome</td>
                        <td>@cliente.CnpjCpf</td>
                        <td>@cliente.Email</td>
                        <td>@cliente.Telefone</td>
                        <td>
                            @if (cliente.Ativo)
                            {
                                <span class="badge bg-success">Sim</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Não</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@cliente.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                            <a asp-action="Details" asp-route-id="@cliente.Id" class="btn btn-sm btn-outline-info">Detalhes</a>
                            <a asp-action="Delete" asp-route-id="@cliente.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
